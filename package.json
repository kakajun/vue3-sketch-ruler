{
  "name": "root",
  "version": "2.4.1",
  "private": true,
  "keywords": [
    "panzoom",
    "room",
    "ruler",
    "sketch",
    "sketch-ruler",
    "vue",
    "vue-sketch-ruler",
    "vue3"
  ],
  "license": "MIT",
  "author": "kakajun <253495832@qq.com>",
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "pnpm build && pnpm --filter ./packages/docs dev",
    "d": "pnpm --filter ./packages/docs dev",
    "build": "pnpm --filter ./packages/sketch-ruler build",
    "build:demo": "pnpm build && pnpm --filter ./packages/docs build",
    "precommit": "lint-staged",
    "clean": "rimraf node_modules && rimraf ./packages/**/node_modules",
    "lint:check": "oxlint",
    "lint": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "pnpm --filter ./packages/sketch-ruler test",
    "changelog": "pnpm --filter ./packages/sketch-ruler changelog",
    "release": "pnpm build && node ./scripts/release.js"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@daybrush/utils": "^1.13.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/babel-plugin-jsx": "^2.0.1",
    "chalk": "^4.1.2",
    "compare-func": "^2.0.0",
    "conventional-changelog": "^7.1.1",
    "conventional-changelog-cli": "^5.0.0",
    "element-plus": "^2.11.8",
    "enquirer": "^2.4.1",
    "esprint": "^3.6.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "highlight.js": "^11.11.1",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^16.2.6",
    "lodash": "^4.17.21",
    "minimist": "^1.2.8",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postcss-html": "^1.8.0",
    "rollup-plugin-banner": "^0.2.1",
    "root-common": "workspace:*",
    "sass": "^1.94.1",
    "selecto": "^1.26.3",
    "semver": "^7.7.3",
    "simple-panzoom": "2.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.10",
    "vue": "^3.5.24",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.6.3",
    "vue-tsc": "^3.1.4",
    "vue3-moveable": "^0.28.0",
    "vue3-sketch-ruler": "workspace:*"
  },
  "lint-staged": {
    "*.{vue,css,less}": "stylelint --fix",
    "*.{js,ts,mjs,cjs,vue}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "pnpm": {
    "overrides": {
      "parse5": "^7.1.2"
    }
  }
}
